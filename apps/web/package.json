{
  "name": "zublo",
  "description": "Web application for the Zublo self-hosted subscription tracker.",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.6",
  "license": "Apache-2.0",
  "author": {
    "name": "Daniel Luiz Alves",
    "url": "https://github.com/danielalves96"
  },
  "homepage": "https://github.com/danielalves96/zublo/tree/main/apps/web",
  "bugs": {
    "url": "https://github.com/danielalves96/zublo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielalves96/zublo.git",
    "directory": "apps/web"
  },
  "keywords": [
    "budget",
    "pocketbase",
    "react",
    "self-hosted",
    "subscriptions",
    "tanstack-router"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage; cp coverage/lcov.info lcov.info || true",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.6.0",
    "@hookform/resolvers": "^5.2.2",
